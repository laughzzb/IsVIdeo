<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="112.92dp"
            android:layout_height="12.52dp"
            android:layout_marginStart="14.6dp"
            android:layout_marginTop="7.5dp"
            android:src="@mipmap/icon_logo"
            app:layout_constraintBottom_toBottomOf="@+id/rg_indicator"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <RadioGroup
            android:id="@+id/rg_indicator"
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            android:layout_marginStart="84.5dp"
            android:layout_marginRight="32dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toStartOf="@+id/iv_notify"
            app:layout_constraintStart_toEndOf="@+id/iv_logo"
            app:layout_constraintTop_toTopOf="parent">

            <RadioButton
                android:id="@+id/rg_recommend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:button="@null"
                android:checked="true"
                android:drawableLeft="@drawable/icon_video_list_indicator"
                android:text="推荐" />

            <RadioButton
                android:id="@+id/rb_daily"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:button="@null"
                android:drawableStart="@drawable/icon_video_list_indicator"
                android:drawablePadding="4dp"
                android:text="日报" />
        </RadioGroup>

        <ImageView
            android:id="@+id/iv_notify"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginTop="7.5dp"
            android:layout_marginRight="14.5dp"
            android:src="@mipmap/icon_notify"
            app:layout_constraintBottom_toBottomOf="@+id/rg_indicator"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/view_pager2"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="14.5dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/iv_logo"
            app:layout_constraintVertical_bias="0.0" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>