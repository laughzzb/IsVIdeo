<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="com.is.mediaPlayer.ui.videodetail.VideoDetailViewModel" />

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/design_default_color_on_secondary"
        android:orientation="vertical">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:layout_marginTop="24dp"
                android:text="@{viewModel.videoInfo.title}"
                android:textColor="#ffffffff"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_channel"
                android:layout_width="86dp"
                android:layout_height="0dp"
                android:layout_marginTop="16dp"
                android:text="@{viewModel.channel}"
                android:textColor="#ffffffff"
                android:textSize="11sp"
                app:layout_constraintStart_toStartOf="@+id/tv_title"
                app:layout_constraintTop_toBottomOf="@+id/tv_title" />

            <TextView
                android:id="@+id/tv_introduction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="15dp"
                android:ellipsize="end"
                android:text="@{viewModel.videoInfo.description}"
                android:textColor="#ffffffff"
                android:textSize="13sp"
                app:layout_constraintStart_toStartOf="@+id/tv_title"
                app:layout_constraintTop_toBottomOf="@+id/tv_channel" />

            <ImageView
                android:id="@+id/iv_like"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="32dp"
                android:layout_marginTop="24dp"
                android:onClick="@{()->viewModel.onLikeClick()}"
                android:src="@{viewModel.isLikes?@drawable/ic_yet_like:@drawable/ic_like}"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_introduction" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@{viewModel.videoInfo.strLikes}"
                android:textColor="#ffffffff"
                android:textSize="11sp"
                app:layout_constraintEnd_toEndOf="@+id/iv_like"
                app:layout_constraintStart_toStartOf="@id/iv_like"
                app:layout_constraintTop_toBottomOf="@id/iv_like" />

            <ImageView
                android:id="@+id/iv_collect"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="77.5dp"
                android:layout_marginTop="24dp"
                android:src="@{viewModel.isCollection?@drawable/ic_yet_collect:@drawable/icon_collect}"
                android:onClick="@{()->viewModel.onCollectClick()}"
                app:layout_constraintStart_toEndOf="@+id/iv_like"
                app:layout_constraintTop_toBottomOf="@+id/tv_introduction" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@{viewModel.videoInfo.strCollection}"
                android:textColor="#ffffffff"
                android:textSize="11sp"
                app:layout_constraintEnd_toEndOf="@+id/iv_collect"
                app:layout_constraintStart_toStartOf="@+id/iv_collect"
                app:layout_constraintTop_toBottomOf="@+id/iv_collect" />

            <ImageView
                android:id="@+id/iv_comment"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="77dp"
                android:layout_marginTop="24dp"
                android:src="@mipmap/ic_comment"
                app:layout_constraintStart_toEndOf="@+id/iv_collect"
                app:layout_constraintTop_toBottomOf="@+id/tv_introduction" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@{viewModel.videoInfo.strComment}"
                android:textColor="#ffffffff"
                android:textSize="11sp"
                app:layout_constraintEnd_toEndOf="@+id/iv_comment"
                app:layout_constraintStart_toStartOf="@+id/iv_comment"
                app:layout_constraintTop_toBottomOf="@+id/iv_comment" />

            <ImageView
                android:id="@+id/iv_share"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="32dp"
                android:src="@mipmap/ic_share"
                android:onClick="@{()->viewModel.share2Wechat()}"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_introduction" />

            <TextView
                android:id="@+id/textView4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@{viewModel.videoInfo.strViews}"
                android:textColor="#ffffffff"
                android:textSize="11sp"
                app:layout_constraintEnd_toEndOf="@id/iv_share"
                app:layout_constraintStart_toStartOf="@+id/iv_share"
                app:layout_constraintTop_toBottomOf="@+id/iv_share" />

            <View
                android:id="@+id/view"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="87dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_introduction" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/fcv"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="24dp" />


    </LinearLayout>
</layout>