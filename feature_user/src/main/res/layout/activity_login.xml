<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="com.is.feature_user.ui.login.LoginViewModel" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:color="#E5E5E5"
        tools:context=".ui.login.LoginActivity">

        <ImageView
            android:id="@+id/iv_background"
            android:layout_width="375dp"
            android:layout_height="340dp"
            android:src="@mipmap/icon_login_background"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/iv_install"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="14dp"
            android:src="@mipmap/ic_install"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/ic_safe"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="12dp"
            android:src="@mipmap/ic_safe"
            app:layout_constraintEnd_toStartOf="@+id/iv_install"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/iv_return"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="14dp"
            android:rotation="180"
            android:src="@mipmap/ic_detail"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@mipmap/icon_logo"
            app:layout_constraintBottom_toBottomOf="@+id/iv_background"
            app:layout_constraintEnd_toEndOf="@+id/iv_background"
            app:layout_constraintStart_toStartOf="@+id/iv_background"
            app:layout_constraintTop_toTopOf="@+id/iv_background"
            app:layout_constraintVertical_bias="0.35" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="340dp"
            android:layout_height="450dp"
            android:layout_marginStart="17.5dp"
            android:layout_marginTop="196dp"
            android:background="#FFFFFF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/textView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="36dp"
                android:layout_marginTop="27.5dp"
                android:text="用户账号"
                android:textColor="#ff000000"
                android:textSize="13sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:layout_width="52dp"
                android:layout_height="1dp"
                android:layout_marginTop="3.5dp"
                android:color="#ff9c9c9c"
                app:layout_constraintStart_toStartOf="@+id/textView"
                app:layout_constraintTop_toBottomOf="@id/textView" />

            <EditText
                android:id="@+id/et_user_name"
                android:layout_width="268dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="54.5dp"
                android:background="@null"
                android:hint="输入手机号登录/注册"
                android:inputType="phone"
                android:text="@={viewModel.userMobile}"
                android:textColor="#ffbbbbbb"
                android:textSize="11sp"
                app:layout_constraintStart_toStartOf="@id/textView"
                app:layout_constraintTop_toBottomOf="@id/textView" />

            <View
                android:id="@+id/view_phone_div"
                android:layout_width="268dp"
                android:layout_height="1dp"
                android:layout_marginTop="8.5dp"
                android:color="#ffbbbbbb"
                app:layout_constraintStart_toStartOf="@id/et_user_name"
                app:layout_constraintTop_toBottomOf="@+id/et_user_name" />

            <EditText
                android:id="@+id/et_password"
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="42.5dp"
                android:background="@null"
                android:hint="输入验证码"
                android:inputType="number"
                android:text="@={viewModel.code}"
                android:textColor="#ffbbbbbb"
                android:textSize="11sp"
                app:layout_constraintStart_toStartOf="@id/textView"
                app:layout_constraintTop_toBottomOf="@+id/view_phone_div" />

            <View
                android:id="@+id/view_code_div"
                android:layout_width="268dp"
                android:layout_height="1dp"
                android:layout_marginTop="8.5dp"
                android:color="#ffbbbbbb"
                app:layout_constraintStart_toStartOf="@+id/et_password"
                app:layout_constraintTop_toBottomOf="@+id/et_password" />

            <TextView
                android:enabled="@{viewModel.isEnableSendCode}"
                android:text="@{viewModel.getVerticalCodeText}"
                android:layout_width="64dp"
                android:layout_height="16dp"
                android:background="@drawable/bg_send_sms"
                android:gravity="center"
                android:paddingBottom="3dp"
                tools:text="获取验证码"
                android:textSize="10dp"
                android:onClick="@{()->viewModel.sendCode()}"
                app:layout_constraintEnd_toEndOf="@+id/view_code_div"
                app:layout_constraintTop_toTopOf="@+id/et_password" />

            <ImageView
                android:id="@+id/iv_qq"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="127dp"
                android:layout_marginTop="58.5dp"
                android:src="@mipmap/icon_qq"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/view_code_div" />

            <ImageView
                android:id="@+id/iv_wv"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="44dp"
                android:src="@mipmap/icon_wx"
                app:layout_constraintStart_toEndOf="@+id/iv_qq"
                app:layout_constraintTop_toTopOf="@+id/iv_qq" />

            <TextView
                android:id="@+id/textView2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_marginTop="56.5dp"
                android:text="新手机号将自动注册"
                android:textColor="#ffbbbbbb"
                android:textSize="10sp"
                app:layout_constraintStart_toStartOf="@+id/iv_qq"
                app:layout_constraintTop_toTopOf="@+id/iv_qq" />

            <CheckBox
                android:id="@+id/cb_agreen"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_marginStart="65dp"
                android:layout_marginTop="9dp"
                android:button="@null"
                android:checked="@={viewModel.checkAgreement}"
                android:drawableStart="@drawable/icon_custom_checkbox"
                android:gravity="center"
                android:text="请阅读并同意《用户协议》和《隐私政策》"
                android:textColor="#ff000000"
                android:textSize="10sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/textView2" />


            <TextView
                android:layout_width="340dp"
                android:layout_height="55dp"
                android:background="@drawable/bg_login_button"
                android:enabled="@{viewModel.IsEnableLogin}"
                android:gravity="center"
                android:onClick="@{()->viewModel.login()}"
                android:text="登 录"
                android:layout_marginTop="15dp"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>